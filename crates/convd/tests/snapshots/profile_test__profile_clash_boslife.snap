    DIRECT_no_resolve: { type: "http", url: "http://127.0.0.1:8080/api/rule-provider?server=http%3A%2F%2F127.0.0.1%3A8080%2F&client=clash&interval=0&strict=false&policy%5Bname%5D=DIRECT&policy%5Boption%5D=no-resolve&policy%5Bis_subscription%5D=false&sub_url=http://127.0.0.1/api/original?token=bppleman path: "./rule_providers/DIRECT_no_resolve.yaml", interval: 0, size-limit: 0, format: "yaml", behavior: "classical" }
