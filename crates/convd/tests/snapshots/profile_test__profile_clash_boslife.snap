proxy-groups:
    { name: "BosLife", type: "select", proxies: [ 🇭🇰 香港, 🇸🇬 新加坡, 🇨🇳🏳️‍🌈 台湾, 🇯🇵 日本, 🇺🇸 美国, 🇨🇦 加拿大, 🇰🇷 韩国, 🇬🇧 英国, 🇫🇷 法国, 🇩🇪 德国 ] }
    { name: "Subscription Info", type: "select", uses: [ convertor ], filter: "(?i)(剩余流量：43.9 GB|距离下次重置剩余：15 天|套餐到期：2026-04-22)" }
    { name: "🇭🇰 香港", type: "url-test", uses: [ convertor ], filter: "(?i)🇭🇰 香港" }
    { name: "🇸🇬 新加坡", type: "url-test", uses: [ convertor ], filter: "(?i)🇸🇬 新加坡" }
    { name: "🇨🇳🏳️‍🌈 台湾", type: "url-test", uses: [ convertor ], filter: "(?i)🏳️‍🌈 台湾" }
    { name: "🇯🇵 日本", type: "url-test", uses: [ convertor ], filter: "(?i)🇯🇵 日本" }
    { name: "🇺🇸 美国", type: "url-test", uses: [ convertor ], filter: "(?i)🇺🇸 美国" }
    { name: "🇨🇦 加拿大", type: "url-test", uses: [ convertor ], filter: "(?i)🇨🇦 加拿大 01" }
    { name: "🇰🇷 韩国", type: "url-test", uses: [ convertor ], filter: "(?i)🇰🇷 韩国 01" }
    { name: "🇬🇧 英国", type: "url-test", uses: [ convertor ], filter: "(?i)🇬🇧 英国 01" }
    { name: "🇫🇷 法国", type: "url-test", uses: [ convertor ], filter: "(?i)🇫🇷 法国 01" }
    { name: "🇩🇪 德国", type: "url-test", uses: [ convertor ], filter: "(?i)🇩🇪 德国 01" }

rule-providers:
    Subscription_policy: { type: "http", url: "http://127.0.0.1:8080/api/rule-provider?server=http%3A%2F%2F127.0.0.1%3A8080%2F&client=clash&interval=0&strict=false&policy%5Bname%5D=DIRECT&policy%5Boption%5D&policy%5Bis_subscription%5D=true&sub_url=http://127.0.0.1/api/original?token=bppleman path: "./rule_providers/Subscription_policy.yaml", interval: 0, size-limit: 0, format: "yaml", behavior: "classical" }
