    { name: "🇰🇷 韩国", type: "url-test", uses: [ convertor ], filter: "(?i)🇰🇷 韩国 01" }
    { name: "🇬🇧 英国", type: "url-test", uses: [ convertor ], filter: "(?i)🇬🇧 英国 01" }
    { name: "🇫🇷 法国", type: "url-test", uses: [ convertor ], filter: "(?i)🇫🇷 法国 01" }
    { name: "🇩🇪 德国", type: "url-test", uses: [ convertor ], filter: "(?i)🇩🇪 德国 01" }

