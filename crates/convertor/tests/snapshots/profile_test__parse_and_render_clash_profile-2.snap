---
source: crates/convertor/tests/profile_test.rs
expression: rendered
---
port: 7890
socks-port: 7891
redir-port: 7892
allow-lan: true
mode: Rule
log-level: info
external-controller: 0.0.0.0:9090
external-ui: 
secret: ""

geo-auto-update: true
geo-update-interval: 24
geox-url:
    geoip: "http://127.0.0.1:8080/download?0%5B0%5D=url&0%5B1%5D=https%3A%2F%2Ftestingcf.jsdelivr.net%2Fgh%2FMetaCubeX%2Fmeta-rules-dat%40release%2Fgeoip.dat"
