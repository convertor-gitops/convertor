proxy-groups:
    { name: "BosLife", type: "select", proxies: [ 🇭🇰 香港, 🇸🇬 新加坡, 🇨🇳🏳️‍🌈 台湾, 🇯🇵 日本, 🇺🇸 美国, 🇨🇦 加拿大, 🇰🇷 韩国, 🇬🇧 英国, 🇫🇷 法国, 🇩🇪 德国 ] }
    { name: "Subscription Info", type: "select", uses: [ convertor ], filter: "(?i)(剩余流量：43.9 GB|距离下次重置剩余：15 天|套餐到期：2026-04-22)" }
    { name: "🇭🇰 香港", type: "url-test", uses: [ convertor ], filter: "(?i)🇭🇰 香港" }
    { name: "🇸🇬 新加坡", type: "url-test", uses: [ convertor ], filter: "(?i)🇸🇬 新加坡" }
    { name: "🇨🇳🏳️‍🌈 台湾", type: "url-test", uses: [ convertor ], filter: "(?i)🏳️‍🌈 台湾" }
    { name: "🇯🇵 日本", type: "url-test", uses: [ convertor ], filter: "(?i)🇯🇵 日本" }
    { name: "🇺🇸 美国", type: "url-test", uses: [ convertor ], filter: "(?i)🇺🇸 美国" }
